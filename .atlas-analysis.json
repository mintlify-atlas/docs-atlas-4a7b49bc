  "keyFeatures": [
    "Structured application mainloop with FPS control and per-second callbacks",
    "Hierarchical GUI framework with Frame containers and widget event binding",
    "Rich event system with 44 built-in events (system, network, database, file, memory, thread)",
    "Async file downloader with pause/resume/cancel control and progress events",
    "Managed thread pool with lifecycle events (create, start, end, error)",
    "File-system watcher with MD5 hash-based change detection",
    "System resource monitoring (memory and disk usage with low-resource alerts)",
    "Page-based UI navigation for multi-screen applications",
    "Color utility class with lerp, grayscale, invert, and CSS/hex parsing",
    "Network connectivity detection with automatic reconnect events"
  ],
  "publicApiSurface": [
    "mainloop(FPS, CALL_PER_SECOND, REVIEW_PATHS, REVIEW_MAIN_DIR)",
